#!/usr/bin/env bash
# Muster — assemble your AI agent team
set -euo pipefail

MUSTER_ROOT="$(cd "$(dirname "$(readlink -f "$0")")" && cd .. && pwd)"
LIB="$MUSTER_ROOT/lib"

source "$LIB/common.sh"

usage() {
  cat <<EOF
${BOLD}muster${RESET} — assemble your AI agent team

${BOLD}Usage:${RESET}
  muster <command>

${BOLD}Commands:${RESET}
  init       Set up a team in the current project
  info       Show project setup and team roster
  add        Add a team member
  remove     Remove a team member
  reset      Wipe comms/ and .opencode/agents/ and start over
  upgrade    Pull the latest version
  version    Print version

${BOLD}Quick start:${RESET}
  cd your-project
  muster init          # wizard: name agents, pick characters, choose a lead
  opencode             # open the project — your agents are ready

${BOLD}How it works:${RESET}
  muster generates OpenCode agent definitions (.opencode/agents/) with
  extreme character personalities. Each agent has persistent memory in
  comms/<name>/journal/ and comms/<name>/notes/. Coordination happens
  through OpenCode's native agent teams system.

${BOLD}Requires:${RESET} python3, opencode

EOF
}

case "${1:-}" in
  info)    source "$LIB/info.sh" ;;
  init)    shift; source "$LIB/init.sh" "$@" ;;
  add)     shift; source "$LIB/add.sh" "$@" ;;
  remove)  shift; source "$LIB/remove.sh" "$@" ;;
  reset)   source "$LIB/reset.sh" ;;
  upgrade) source "$LIB/upgrade.sh" ;;
  version) echo "muster $MUSTER_VERSION" ;;
  -h|--help|"") usage ;;
  *)       die "Unknown command: $1. Run 'muster --help' for usage." ;;
esac
